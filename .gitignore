# ========== SMARTPATH CONFIGURATIONS REPOSITORY ==========
# This .gitignore ensures only templates and shared resources are tracked
# User-created microscope-specific configurations are excluded

# ========== IGNORE ALL USER CONFIGURATIONS ==========
# Ignore all YAML config files by default
*.yml
*.yaml

# ========== INCLUDE TEMPLATES AND EXAMPLE CONFIGS ==========
# Re-include template files (these are tracked in the repository)
!*template*.yml
!*template*.yaml

# Include example microscope configs (for reference / new system setup)
!config_OWS3.yml
!autofocus_OWS3.yml
# Mock configs for CI-adjacent testing against the MM Demo adapter
!config_mock.yml
!autofocus_mock.yml

# Include templates folder and all contents
!templates/
!templates/**

# Include GitHub Actions workflows (.yml files under .github/)
!.github/
!.github/**

# ========== INCLUDE SHARED RESOURCES ==========
# Always include the resources folder and its contents
!resources/
!resources/**

# ========== IGNORE TEST AND TEMPORARY FILES ==========
# Test result directories
autofocus_tests/
ppm_sensitivity_tests/
ppm_birefringence_tests/
*_tests/

# Image files
*.tif
*.tiff
*.png
*.jpg
*.jpeg

# Jupyter notebooks and checkpoints
.ipynb_checkpoints/
*.ipynb

# Data and output files
*.log
*.txt
*.npz
*.csv

# Re-include device property dumps (developer reference)
!mm_device_properties_*.txt

# Temporary and backup files
*.bak
*.tmp
*~
.DS_Store
Thumbs.db

# Saved state files
saved_transforms.json
*.json

# Calibration output directories (generated at runtime on microscope PC)
white_balance_calibration/
ppm_reference_slide/

# Archive directories
archive/
_*/

# Testing files
testing*
test_*
